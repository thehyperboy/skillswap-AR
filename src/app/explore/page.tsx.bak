'use client';

import { useState, useEffect } from 'react';

interface NearbyUser {
  userId: string;
  displayName: string;
  city?: string;
  locality?: string;
  latitude: number;
  longitude: number;
  distanceKm: number;
  collaborationMode: 'ONLINE' | 'OFFLINE' | 'HYBRID';
  skillKarma: number;
  locationPrivacy: 'PUBLIC' | 'APPROXIMATE' | 'PRIVATE';
}

export default function ExplorePage() {
  const [userLocation, setUserLocation] = useState<{ latitude: number; longitude: number } | null>(null);
  const [nearbyUsers, setNearbyUsers] = useState<NearbyUser[]>([]);
  const [loading, setLoading] = useState(false);

  // Get user location
  useEffect(() => {
    setUserLocation({ latitude: 40.7128, longitude: -74.0060 });
  }, []);

  const fetchNearbyUsers = async () => {
    if (!userLocation) return;

    setLoading(true);
    try {
      const response = await fetch(
        `/api/nearby?lat=${userLocation.latitude}&lon=${userLocation.longitude}&radius=10`
      );
      if (response.ok) {
        const data = await response.json();
        setNearbyUsers(data.nearby);
      } else {
        console.error('Failed to fetch nearby users');
      }
    } catch (error) {
      console.error('Error fetching nearby users:', error);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="space-y-6 pb-10">
      <h1>Explore nearby</h1>
      <p>Find skill exchange opportunities</p>

      {userLocation && (
        <div>
          <p>Location: {userLocation.latitude}, {userLocation.longitude}</p>
          <button onClick={fetchNearbyUsers}>Fetch Nearby</button>
          {loading && <p>Loading...</p>}
          <ul>
            {nearbyUsers.map((user) => (
              <li key={user.userId}>{user.displayName} - {user.distanceKm}km</li>
            ))}
          </ul>
        </div>
      )}
    </div>
  );
}
